generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ─── Tenant & Organization ───
model Tenant {
  id          String   @id @default(cuid())
  name        String
  industry    String
  gstNumber   String?
  panNumber   String?
  address     String?
  city        String?
  state       String?
  country     String   @default("India")
  currency    String   @default("INR")
  timezone    String   @default("Asia/Kolkata")
  employees   Employee[]
  departments Department[]
  projects    Project[]
  invoices    Invoice[]
  vendors     Vendor[]
  assets      Asset[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Department {
  id        String   @id @default(cuid())
  name      String
  code      String
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  headId    String?
  employees Employee[]
  projects  Project[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─── Employees ───
model Employee {
  id                String       @id @default(cuid())
  tenantId          String
  tenant            Tenant       @relation(fields: [tenantId], references: [id])
  departmentId      String
  department        Department   @relation(fields: [departmentId], references: [id])
  firstName         String
  lastName          String
  email             String
  phone             String?
  designation       String
  managerId         String?
  salaryBand        String?
  baseSalary        Float        @default(0)
  joinDate          DateTime
  status            String       @default("active") // active, on-leave, notice-period, inactive, probation
  productivityScore Float        @default(0)
  avatar            String?
  attendance        Attendance[]
  leaves            LeaveRequest[]
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt
}

// ─── Projects ───
model Project {
  id             String     @id @default(cuid())
  tenantId       String
  tenant         Tenant     @relation(fields: [tenantId], references: [id])
  departmentId   String?
  department     Department? @relation(fields: [departmentId], references: [id])
  name           String
  client         String
  accountManager String
  budget         Float      @default(0)
  actualSpend    Float      @default(0)
  progress       Float      @default(0)
  profitability  Float      @default(0)
  health         String     @default("good") // excellent, good, at-risk, critical
  sla            Float      @default(0)
  dueDate        DateTime
  status         String     @default("active") // active, on-hold, completed, cancelled, inception
  priority       String     @default("medium") // low, medium, high, critical
  isRecurring    Boolean    @default(false)
  milestones     Milestone[]
  tasks          Task[]
  invoices       Invoice[]
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
}

model Milestone {
  id        String   @id @default(cuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id])
  title     String
  date      DateTime
  completed Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Task {
  id          String   @id @default(cuid())
  projectId   String
  project     Project  @relation(fields: [projectId], references: [id])
  title       String
  description String?
  stage       String   @default("todo") // backlog, todo, in-progress, review, done, blocked
  assignee    String?
  dueDate     DateTime?
  storyPoints Int      @default(0)
  timeLogged  Float    @default(0)
  isBlocked   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ─── Finance ───
model Invoice {
  id          String   @id @default(cuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id])
  projectId   String?
  project     Project? @relation(fields: [projectId], references: [id])
  invoiceNo   String
  client      String
  amount      Float
  gst         Float    @default(0)
  dueDate     DateTime
  paidAmount  Float    @default(0)
  status      String   @default("draft") // draft, sent, paid, overdue, partial
  recurring   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Vendor {
  id            String   @id @default(cuid())
  tenantId      String
  tenant        Tenant   @relation(fields: [tenantId], references: [id])
  name          String
  type          String
  contractValue Float    @default(0)
  payoutDue     Float    @default(0)
  slaScore      Float    @default(0)
  qualityScore  Float    @default(0)
  rating        Float    @default(0)
  status        String   @default("active") // active, on-notice, suspended, terminated
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

// ─── Assets ───
model Asset {
  id           String   @id @default(cuid())
  tenantId     String
  tenant       Tenant   @relation(fields: [tenantId], references: [id])
  name         String
  type         String
  serialNo     String
  assignedTo   String?
  warrantyEnd  DateTime?
  status       String   @default("active") // active, in-repair, disposed, retired
  purchaseDate DateTime
  purchaseCost Float    @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// ─── Attendance & Leaves ───
model Attendance {
  id         String   @id @default(cuid())
  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [id])
  date       DateTime
  checkIn    DateTime?
  checkOut   DateTime?
  hours      Float    @default(0)
  overtime   Float    @default(0)
  status     String   @default("present") // present, absent, half-day, wfh, on-leave
  isAnomaly  Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model LeaveRequest {
  id         String   @id @default(cuid())
  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [id])
  type       String   @default("casual") // casual, sick, earned, maternity, paternity, comp-off, loss-of-pay
  startDate  DateTime
  endDate    DateTime
  days       Int      @default(1)
  status     String   @default("pending") // pending, approved, rejected, cancelled
  reason     String?
  approver   String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

// ─── Deliveries ───
model Delivery {
  id             String   @id @default(cuid())
  projectId      String
  deliverable    String
  status         String   @default("pending") // pending, in-progress, review, client-review, approved, revision, delivered
  dueDate        DateTime?
  clientApproval Boolean  @default(false)
  revisionRounds Int      @default(0)
  assignedTo     String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

// ─── Approvals ───
model Approval {
  id          String   @id @default(cuid())
  type        String   @default("content") // content, design, invoice, budget, payroll, leave, proposal
  title       String
  requestedBy String?
  status      String   @default("pending") // pending, approved, rejected, escalated
  project     String?
  version     Int      @default(1)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ─── Workload ───
model WorkloadEntry {
  id          String   @id @default(cuid())
  employeeId  String
  allocation  Float    @default(0)
  capacity    Float    @default(100)
  projects    String   @default("[]") // JSON array of project names
  overtime    Float    @default(0)
  status      String   @default("optimal") // optimal, under-utilized, overloaded, at-capacity
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ─── Keep existing User/Post for compatibility ───
model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Post {
  id        String   @id @default(cuid())
  title     String
  content   String?
  published Boolean  @default(false)
  authorId  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
